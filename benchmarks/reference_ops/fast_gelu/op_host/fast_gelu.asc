/**
 * @file fast_gelu.asc
 * @brief Host runner for FP32 FastGelu direct-invoke skeleton.
 */

#include "data_utils.h"
#include "../op_kernel/fast_gelu_tiling.h"

#include <acl/acl.h>

#include <cstdint>
#include <cstdio>
#include <cstdlib>
#include <string>
#include <vector>

#include "../op_kernel/fast_gelu_kernel.asc"

static FastGeluTilingData ComputeTiling(uint32_t totalLength, uint32_t coreNum)
{
    FastGeluTilingData tiling{};
    tiling.totalLength = totalLength;

    const uint64_t totalTiles = (totalLength + TILE_LENGTH - 1) / TILE_LENGTH;
    const uint64_t tilesPerCore = (totalTiles + coreNum - 1) / coreNum;
    tiling.blockNum = static_cast<uint32_t>((totalTiles + tilesPerCore - 1) / tilesPerCore);
    tiling.numPerCore = static_cast<uint32_t>(tilesPerCore * TILE_LENGTH);
    tiling.tailNumLastCore = totalLength - tiling.numPerCore * (tiling.blockNum - 1);
    return tiling;
}

static bool CheckAcl(aclError ret, const char* what)
{
    if (ret == ACL_SUCCESS) {
        return true;
    }
    fprintf(stderr, "[ERROR] %s failed: %d\n", what, ret);
    return false;
}

static int RunFastGelu(const std::string& inputPath, const std::string& outputPath, uint32_t totalLength,
                       uint32_t coreNum)
{
    const size_t ioBytes = static_cast<size_t>(totalLength) * sizeof(float);
    std::vector<uint8_t> hostInput(ioBytes);
    std::vector<uint8_t> hostOutput(ioBytes, 0);
    ReadBinaryFile(inputPath, hostInput.data(), ioBytes);

    int32_t deviceId = 0;
    aclrtStream stream = nullptr;
    void* devInput = nullptr;
    void* devOutput = nullptr;
    void* devTiling = nullptr;

    if (!CheckAcl(aclInit(nullptr), "aclInit")) {
        return 1;
    }
    if (!CheckAcl(aclrtSetDevice(deviceId), "aclrtSetDevice")) {
        return 1;
    }
    if (!CheckAcl(aclrtCreateStream(&stream), "aclrtCreateStream")) {
        return 1;
    }

    FastGeluTilingData tiling = ComputeTiling(totalLength, coreNum);
    printf("[INFO] Tiling: totalLength=%u, blockNum=%u, numPerCore=%u, tailNumLastCore=%u\n", tiling.totalLength,
           tiling.blockNum, tiling.numPerCore, tiling.tailNumLastCore);

    if (!CheckAcl(aclrtMalloc(&devInput, ioBytes, ACL_MEM_MALLOC_HUGE_FIRST), "aclrtMalloc input") ||
        !CheckAcl(aclrtMalloc(&devOutput, ioBytes, ACL_MEM_MALLOC_HUGE_FIRST), "aclrtMalloc output") ||
        !CheckAcl(aclrtMalloc(&devTiling, sizeof(FastGeluTilingData), ACL_MEM_MALLOC_HUGE_FIRST), "aclrtMalloc tiling")) {
        return 1;
    }

    if (!CheckAcl(aclrtMemcpy(devInput, ioBytes, hostInput.data(), ioBytes, ACL_MEMCPY_HOST_TO_DEVICE),
                  "aclrtMemcpy input H2D") ||
        !CheckAcl(aclrtMemcpy(devTiling, sizeof(FastGeluTilingData), &tiling, sizeof(FastGeluTilingData),
                              ACL_MEMCPY_HOST_TO_DEVICE),
                  "aclrtMemcpy tiling H2D")) {
        return 1;
    }

    fast_gelu_kernel<<<tiling.blockNum, nullptr, stream>>>(static_cast<uint8_t*>(devInput),
                                                           static_cast<uint8_t*>(devOutput),
                                                           static_cast<uint8_t*>(devTiling));
    if (!CheckAcl(aclrtSynchronizeStream(stream), "aclrtSynchronizeStream")) {
        return 1;
    }

    if (!CheckAcl(aclrtMemcpy(hostOutput.data(), ioBytes, devOutput, ioBytes, ACL_MEMCPY_DEVICE_TO_HOST),
                  "aclrtMemcpy output D2H")) {
        return 1;
    }

    WriteBinaryFile(outputPath, hostOutput.data(), ioBytes);
    printf("[INFO] Output written to %s\n", outputPath.c_str());

    aclrtFree(devTiling);
    aclrtFree(devOutput);
    aclrtFree(devInput);
    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}

int main(int argc, char* argv[])
{
    uint32_t m = (argc > 1) ? static_cast<uint32_t>(std::stoul(argv[1])) : 8;
    uint32_t n = (argc > 2) ? static_cast<uint32_t>(std::stoul(argv[2])) : 2048;
    std::string dtype = (argc > 3) ? argv[3] : "fp32";
    uint32_t coreNum = (argc > 4) ? static_cast<uint32_t>(std::stoul(argv[4])) : 1;

    if (dtype != "fp32" && dtype != "float32" && dtype != "float") {
        fprintf(stderr, "[ERROR] This skeleton currently supports FP32 only, got dtype=%s\n", dtype.c_str());
        return 1;
    }
    if (m == 0 || n == 0 || coreNum == 0) {
        fprintf(stderr, "[ERROR] M, N and coreNum must be greater than 0\n");
        return 1;
    }

    const uint32_t totalLength = m * n;
    printf("[INFO] FastGelu skeleton: shape=[%u, %u], totalLength=%u, dtype=fp32, cores=%u\n", m, n, totalLength,
           coreNum);
    return RunFastGelu("../data/input.bin", "output/output.bin", totalLength, coreNum);
}
