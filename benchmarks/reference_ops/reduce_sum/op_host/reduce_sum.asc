/**
 * @file reduce_sum.asc
 * @brief Minimal host runner for the FP32 ReduceSum direct-invoke skeleton.
 */

#include "data_utils.h"
#include "../op_kernel/reduce_sum_tiling.h"

#include <acl/acl.h>

#include <algorithm>
#include <cstdint>
#include <cstdio>
#include <cstdlib>
#include <string>
#include <vector>

#include "../op_kernel/reduce_sum_kernel.asc"

static uint32_t CeilDiv(uint32_t a, uint32_t b)
{
    return (a + b - 1) / b;
}

static uint32_t AlignDown(uint32_t value, uint32_t align)
{
    return (value / align) * align;
}

static uint32_t AlignUp(uint32_t value, uint32_t align)
{
    return ((value + align - 1) / align) * align;
}

static ReduceSumTilingData ComputeTiling(uint32_t m, uint32_t n, uint32_t coreNum, uint32_t ubSize)
{
    constexpr uint32_t kFp32Size = sizeof(float);
    constexpr uint32_t kElemsPerBlock = 32 / kFp32Size;
    constexpr uint32_t kReservedUbBytes = 1024;

    ReduceSumTilingData tiling{};
    tiling.m = m;
    tiling.n = n;
    tiling.inputStrideN = AlignUp(n, kElemsPerBlock);
    tiling.rowsPerCore = CeilDiv(m, coreNum);

    uint32_t usableUb = (ubSize > kReservedUbBytes) ? (ubSize - kReservedUbBytes) : ubSize;
    uint32_t maxElements = AlignDown(usableUb / kFp32Size, kElemsPerBlock);
    if (maxElements == 0) {
        maxElements = kElemsPerBlock;
    }

    tiling.perLoopN = std::min(n, maxElements);
    if (tiling.perLoopN == 0) {
        return tiling;
    }
    tiling.perLoopN = AlignDown(tiling.perLoopN, kElemsPerBlock);
    if (tiling.perLoopN == 0) {
        tiling.perLoopN = kElemsPerBlock;
    }
    if (tiling.perLoopN > n) {
        tiling.perLoopN = n;
    }

    tiling.perLoopNAligned = AlignUp(tiling.perLoopN, kElemsPerBlock);
    tiling.loopCount = CeilDiv(n, tiling.perLoopN);
    tiling.tailN = n % tiling.perLoopN;
    return tiling;
}

static bool CheckAcl(aclError ret, const char* what)
{
    if (ret == ACL_SUCCESS) {
        return true;
    }
    fprintf(stderr, "[ERROR] %s failed: %d\n", what, ret);
    return false;
}

static int RunReduceSum(const std::string& inputPath, const std::string& outputPath, uint32_t m, uint32_t n,
                        uint32_t coreNum)
{
    constexpr uint32_t kFp32Size = sizeof(float);
    const uint32_t inputStrideN = AlignUp(n, 32 / kFp32Size);
    const size_t inputBytes = static_cast<size_t>(m) * n * kFp32Size;
    const size_t paddedInputBytes = static_cast<size_t>(m) * inputStrideN * kFp32Size;
    const size_t outputBytes = static_cast<size_t>(m) * kFp32Size;

    std::vector<uint8_t> hostInput(inputBytes);
    std::vector<uint8_t> hostInputPadded(paddedInputBytes, 0);
    std::vector<uint8_t> hostOutput(outputBytes, 0);
    ReadBinaryFile(inputPath, hostInput.data(), inputBytes);
    for (uint32_t row = 0; row < m; ++row) {
        const float* src = reinterpret_cast<const float*>(hostInput.data()) + static_cast<size_t>(row) * n;
        float* dst = reinterpret_cast<float*>(hostInputPadded.data()) + static_cast<size_t>(row) * inputStrideN;
        std::copy(src, src + n, dst);
    }

    int32_t deviceId = 0;
    aclrtStream stream = nullptr;
    void* devInput = nullptr;
    void* devOutput = nullptr;
    void* devTiling = nullptr;

    if (!CheckAcl(aclInit(nullptr), "aclInit")) {
        return 1;
    }
    if (!CheckAcl(aclrtSetDevice(deviceId), "aclrtSetDevice")) {
        return 1;
    }
    if (!CheckAcl(aclrtCreateStream(&stream), "aclrtCreateStream")) {
        return 1;
    }

    constexpr uint32_t kDefaultUbSize = 240 * 1024;
    ReduceSumTilingData tiling = ComputeTiling(m, n, coreNum, kDefaultUbSize);
    printf("[INFO] Tiling: inputStrideN=%u, rowsPerCore=%u, perLoopN=%u, perLoopNAligned=%u, loopCount=%u, tailN=%u\n",
           tiling.inputStrideN, tiling.rowsPerCore, tiling.perLoopN, tiling.perLoopNAligned, tiling.loopCount,
           tiling.tailN);

    if (!CheckAcl(aclrtMalloc(&devInput, paddedInputBytes, ACL_MEM_MALLOC_HUGE_FIRST), "aclrtMalloc input") ||
        !CheckAcl(aclrtMalloc(&devOutput, outputBytes, ACL_MEM_MALLOC_HUGE_FIRST), "aclrtMalloc output") ||
        !CheckAcl(aclrtMalloc(&devTiling, sizeof(ReduceSumTilingData), ACL_MEM_MALLOC_HUGE_FIRST),
                  "aclrtMalloc tiling")) {
        return 1;
    }

    if (!CheckAcl(aclrtMemcpy(devInput, paddedInputBytes, hostInputPadded.data(), paddedInputBytes,
                              ACL_MEMCPY_HOST_TO_DEVICE),
                  "aclrtMemcpy input H2D") ||
        !CheckAcl(aclrtMemcpy(devTiling, sizeof(ReduceSumTilingData), &tiling, sizeof(ReduceSumTilingData),
                              ACL_MEMCPY_HOST_TO_DEVICE),
                  "aclrtMemcpy tiling H2D")) {
        return 1;
    }

    reduce_sum_kernel<<<coreNum, nullptr, stream>>>(static_cast<uint8_t*>(devInput),
                                                    static_cast<uint8_t*>(devOutput),
                                                    static_cast<uint8_t*>(devTiling));
    if (!CheckAcl(aclrtSynchronizeStream(stream), "aclrtSynchronizeStream")) {
        return 1;
    }

    if (!CheckAcl(aclrtMemcpy(hostOutput.data(), outputBytes, devOutput, outputBytes, ACL_MEMCPY_DEVICE_TO_HOST),
                  "aclrtMemcpy output D2H")) {
        return 1;
    }

    WriteBinaryFile(outputPath, hostOutput.data(), outputBytes);
    printf("[INFO] Output written to %s\n", outputPath.c_str());

    aclrtFree(devTiling);
    aclrtFree(devOutput);
    aclrtFree(devInput);
    aclrtDestroyStream(stream);
    aclrtResetDevice(deviceId);
    aclFinalize();
    return 0;
}

int main(int argc, char* argv[])
{
    uint32_t m = (argc > 1) ? static_cast<uint32_t>(std::stoul(argv[1])) : 8;
    uint32_t n = (argc > 2) ? static_cast<uint32_t>(std::stoul(argv[2])) : 2048;
    std::string dtype = (argc > 3) ? argv[3] : "fp32";
    uint32_t coreNum = (argc > 4) ? static_cast<uint32_t>(std::stoul(argv[4])) : 1;

    if (dtype != "fp32" && dtype != "float32" && dtype != "float") {
        fprintf(stderr, "[ERROR] This skeleton currently supports FP32 only, got dtype=%s\n", dtype.c_str());
        return 1;
    }
    if (m == 0 || n == 0 || coreNum == 0) {
        fprintf(stderr, "[ERROR] M, N and coreNum must be greater than 0\n");
        return 1;
    }

    printf("[INFO] ReduceSum skeleton: M=%u, N=%u, dtype=fp32, cores=%u\n", m, n, coreNum);
    return RunReduceSum("../data/input.bin", "output/output.bin", m, n, coreNum);
}
