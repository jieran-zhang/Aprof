/**
 * @file reduce_sum_kernel.asc
 * @brief Minimal FP32 ReduceSum kernel shell using reduce_common.h.
 */

#include "kernel_operator.h"
#include "reduce_common.h"
#include "reduce_sum_tiling.h"

using namespace AscendC;

extern "C" __global__ __vector__ void reduce_sum_kernel(
    __gm__ uint8_t* inputGM,
    __gm__ uint8_t* outputGM,
    __gm__ uint8_t* tilingGM)
{
    __gm__ ReduceSumTilingData* tilingPtr = reinterpret_cast<__gm__ ReduceSumTilingData*>(tilingGM);
    ReduceSumTilingData tiling;
    tiling.m = tilingPtr->m;
    tiling.n = tilingPtr->n;
    tiling.inputStrideN = tilingPtr->inputStrideN;
    tiling.rowsPerCore = tilingPtr->rowsPerCore;
    tiling.perLoopN = tilingPtr->perLoopN;
    tiling.perLoopNAligned = tilingPtr->perLoopNAligned;
    tiling.loopCount = tilingPtr->loopCount;
    tiling.tailN = tilingPtr->tailN;

    const uint32_t blockIdx = GetBlockIdx();
    const uint32_t startRow = blockIdx * tiling.rowsPerCore;
    if (startRow >= tiling.m || tiling.n == 0 || tiling.perLoopN == 0) {
        return;
    }

    uint32_t rowCount = tiling.rowsPerCore;
    if (startRow + rowCount > tiling.m) {
        rowCount = tiling.m - startRow;
    }

    TPipe pipe;
    TBuf<> inputBuf;
    pipe.InitBuffer(inputBuf, tiling.perLoopNAligned * sizeof(float));
    LocalTensor<float> inputLocal = inputBuf.Get<float>();

    __gm__ float* gmOut = reinterpret_cast<__gm__ float*>(outputGM);
    GlobalTensor<float> inputGlobal;
    inputGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(inputGM));

    for (uint32_t localRow = 0; localRow < rowCount; ++localRow) {
        const uint32_t globalRow = startRow + localRow;
        float rowSum = 0.0f;

        for (uint32_t loop = 0; loop < tiling.loopCount; ++loop) {
            const uint32_t curN =
                (loop == tiling.loopCount - 1 && tiling.tailN != 0) ? tiling.tailN : tiling.perLoopN;
            const uint32_t curNAligned =
                ((curN + ELEM_PER_BLK_FP32 - 1) / ELEM_PER_BLK_FP32) * ELEM_PER_BLK_FP32;
            const uint32_t colOffset = loop * tiling.perLoopN;
            const uint32_t gmOffset = globalRow * tiling.inputStrideN + colOffset;

            Duplicate(inputLocal, ZERO, tiling.perLoopNAligned);
            PipeBarrier<PIPE_V>();

            DataCopyParams copyParams;
            copyParams.blockCount = 1;
            copyParams.blockLen = curNAligned / ELEM_PER_BLK_FP32;
            copyParams.srcStride = 0;
            copyParams.dstStride = 0;

            DataCopy(inputLocal, inputGlobal[gmOffset], copyParams);
            PipeBarrier<PIPE_ALL>();

            rowSum += ReduceSumHalfInterval(inputLocal, static_cast<int32_t>(curN));
        }

        gmOut[globalRow] = rowSum;
    }
}
