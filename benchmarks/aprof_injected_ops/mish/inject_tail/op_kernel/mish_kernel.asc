#include "kernel_operator.h"
#include "aprof_vector_tiling.h"
#include "aprof_variant_config.h"

using namespace AscendC;

namespace {
constexpr uint32_t kFp32BlockElems = 8;

__aicore__ inline uint32_t MinU32(uint32_t a, uint32_t b)
{
    return a < b ? a : b;
}

__aicore__ inline uint32_t AlignUpU32(uint32_t value, uint32_t align)
{
    return ((value + align - 1) / align) * align;
}

__aicore__ inline void LoadTiling(__gm__ uint8_t* tilingGM, AprofVectorTilingData& tiling)
{
    __gm__ AprofVectorTilingData* ptr = reinterpret_cast<__gm__ AprofVectorTilingData*>(tilingGM);
    tiling.inputElements = ptr->inputElements;
    tiling.outputElements = ptr->outputElements;
    tiling.inputStride = ptr->inputStride;
    tiling.outputStride = ptr->outputStride;
    tiling.elemsPerCore = ptr->elemsPerCore;
    tiling.tileLength = ptr->tileLength;
    tiling.tileLengthAligned = ptr->tileLengthAligned;
    tiling.tileNum = ptr->tileNum;
    tiling.tailLength = ptr->tailLength;
    tiling.variantFlags = ptr->variantFlags;
}

__aicore__ inline void MaybeInjectTailReload(LocalTensor<float>& local, GlobalTensor<float>& gm, uint32_t offset,
                                             const DataCopyParams& copyParams, uint32_t curN, uint32_t tileLength)
{
#if APROF_INJECT_TAIL
    if (curN < tileLength) {
        DataCopy(local, gm[offset], copyParams);
        PipeBarrier<PIPE_ALL>();
    }
#endif
}
} // namespace

extern "C" __global__ __vector__ void mish_kernel(__gm__ uint8_t* inputGM, __gm__ uint8_t* outputGM,
                                                   __gm__ uint8_t* tilingGM)
{
    AprofVectorTilingData tiling;
    LoadTiling(tilingGM, tiling);
    if (tiling.outputElements == 0 || tiling.tileLength == 0 || tiling.tileLengthAligned == 0) {
        return;
    }

    const uint32_t blockIdx = GetBlockIdx();
    const uint32_t coreStart = blockIdx * tiling.elemsPerCore;
    if (coreStart >= tiling.outputElements) {
#if APROF_INJECT_DYNSHAPE
        PipeBarrier<PIPE_ALL>();
#endif
        return;
    }
    const uint32_t coreElems = MinU32(tiling.elemsPerCore, tiling.outputElements - coreStart);

    TPipe pipe;
    TBuf<> aBuf;
    TBuf<> bBuf;
    TBuf<> tmpBuf;
    TBuf<> outBuf;
    pipe.InitBuffer(aBuf, tiling.tileLengthAligned * sizeof(float));
    pipe.InitBuffer(bBuf, tiling.tileLengthAligned * sizeof(float));
    pipe.InitBuffer(tmpBuf, tiling.tileLengthAligned * sizeof(float));
    pipe.InitBuffer(outBuf, tiling.tileLengthAligned * sizeof(float));

    LocalTensor<float> aLocal = aBuf.Get<float>();
    LocalTensor<float> bLocal = bBuf.Get<float>();
    LocalTensor<float> tmpLocal = tmpBuf.Get<float>();
    LocalTensor<float> outLocal = outBuf.Get<float>();

    GlobalTensor<float> inputGlobal;
    GlobalTensor<float> outputGlobal;
    inputGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(inputGM), tiling.inputStride);
    outputGlobal.SetGlobalBuffer(reinterpret_cast<__gm__ float*>(outputGM), tiling.outputStride);

    for (uint32_t tileIdx = 0; tileIdx < tiling.tileNum; ++tileIdx) {
        const uint32_t localOffset = tileIdx * tiling.tileLength;
        if (localOffset >= coreElems) {
            PipeBarrier<PIPE_ALL>();
            continue;
        }
        const uint32_t curN = MinU32(tiling.tileLength, coreElems - localOffset);
        const uint32_t curAligned = AlignUpU32(curN, kFp32BlockElems);
        const uint32_t outOffset = coreStart + localOffset;

        DataCopyParams copyParams;
        copyParams.blockCount = 1;
        copyParams.blockLen = curAligned / kFp32BlockElems;
        copyParams.srcStride = 0;
        copyParams.dstStride = 0;

        DataCopy(aLocal, inputGlobal[outOffset], copyParams);
        PipeBarrier<PIPE_ALL>();
        MaybeInjectTailReload(aLocal, inputGlobal, outOffset, copyParams, curN, tiling.tileLength);

        // y = x * tanh(log(1 + exp(x)))
        Exp(tmpLocal, aLocal, curN);
        PipeBarrier<PIPE_V>();
        Adds(tmpLocal, tmpLocal, 1.0f, curN);
        PipeBarrier<PIPE_V>();
        Ln(tmpLocal, tmpLocal, curN);
        PipeBarrier<PIPE_V>();
        Tanh(tmpLocal, tmpLocal, curN);
        PipeBarrier<PIPE_V>();
        Mul(outLocal, aLocal, tmpLocal, curN);

        PipeBarrier<PIPE_ALL>();
        DataCopy(outputGlobal[outOffset], outLocal, copyParams);
    }
}
